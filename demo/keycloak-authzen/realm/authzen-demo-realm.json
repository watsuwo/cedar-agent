{
  "realm": "authzen-demo",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,

  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\"},{\"name\":\"email\"}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
          ]
        }
      }
    ]
  },

  "clients": [
    {
      "clientId": "internal-portal",
      "name": "Internal Portal (employees, internal network)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:9000/*"],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "partner-portal",
      "name": "Partner Portal (partner orgs)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:9000/*"],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "public-app",
      "name": "Public App (any authenticated user)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:9000/*"],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ],

  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@acme.example",
      "firstName": "Alice",
      "lastName": "Employee",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "attributes": {
        "user_type": ["employee"],
        "organization": ["acme"]
      }
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@globex.example",
      "firstName": "Bob",
      "lastName": "Partner",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "attributes": {
        "user_type": ["partner"],
        "organization": ["globex"]
      }
    },
    {
      "username": "carol",
      "enabled": true,
      "emailVerified": true,
      "email": "carol@initech.example",
      "firstName": "Carol",
      "lastName": "Contractor",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "attributes": {
        "user_type": ["contractor"],
        "organization": ["initech"]
      }
    }
  ],

  "authenticatorConfig": [
    {
      "alias": "authzen-config",
      "config": {
        "pdpUrl": "http://cedar-agent:8180",
        "action": "login",
        "resourceType": "Client",
        "failOpen": "false"
      }
    }
  ],

  "authenticationFlows": [
    {
      "alias": "browser-authzen",
      "description": "Browser flow that performs an AuthZEN access evaluation after password login",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "flowAlias": "browser-authzen-forms",
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "browser-authzen-forms",
      "description": "Username/password form followed by the AuthZEN access evaluation",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "authzen-access-evaluation",
          "authenticatorConfig": "authzen-config",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    }
  ],

  "browserFlow": "browser-authzen"
}
